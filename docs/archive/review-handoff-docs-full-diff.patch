+
+// ═══ Step: Savings ═══
+
+function SavingsStep({
+  config,
+  onUpdate,
+  onNext,
+  onBack,
+}: {
+  config: ConfigAnswers
+  onUpdate: (u: Partial<ConfigAnswers>) => void
+  onNext: () => void
